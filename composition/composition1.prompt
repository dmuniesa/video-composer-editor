{"song":{"duration":157.47,"bpm":143.55,"sections":[{"start":0.0,"end":12.89,"label":"intro","energy":0.67,"vocal_ratio":0.0},{"start":12.89,"end":39.68,"label":"verse","energy":0.53,"vocal_ratio":0.996},{"start":39.68,"end":72.75,"label":"verse","energy":0.75,"vocal_ratio":0.909},{"start":72.75,"end":92.65,"label":"chorus","energy":1.0,"vocal_ratio":1.0},{"start":92.65,"end":119.1,"label":"verse","energy":0.71,"vocal_ratio":0.887},{"start":119.1,"end":139.44,"label":"chorus","energy":1.0,"vocal_ratio":1.0},{"start":139.44,"end":157.47,"label":"outro","energy":0.61,"vocal_ratio":0.974}],"downbeats":[1.37,3.04,4.69,6.34,7.99,9.64,11.31,12.93,14.49,16.14,17.79,19.44,21.11,22.76,24.4,26.05,27.72,29.37,31.02,32.67,34.34,35.99,37.64,39.31,40.96,42.61,44.26,45.93,47.58,49.23,50.87,52.52,54.2,55.84,57.49,59.16,60.81,62.46,64.11,65.76,67.43,69.08,70.73,72.38,74.05,75.7,77.35,79.02,80.67,82.31,83.96,85.64,87.28,88.93,90.58,92.25,93.9,95.55,97.2,98.85,100.52,102.17,103.82,105.47,107.14,108.79,110.43,112.08,113.75,115.4,117.05,118.72],"lyrics_language":"es","lyrics":[{"start":13.0,"end":17.0,"text":"Raquel camina donde el cristal se funde con el aire"},{"start":19.0,"end":24.0,"text":"David detiene el tiempo en la penumbra del gran valle"},{"start":26.0,"end":31.0,"text":"Hipop\u00f3tamos de espuma abren bocas de secreto"},{"start":33.0,"end":37.0,"text":"Mientras In\u00e9s busca el diente de un reptil en el quieto"},{"start":37.0,"end":40.0,"text":"Umbral de piedra, cuenta historias de gigantes"},{"start":40.0,"end":44.0,"text":"Sin barrotes, solo el rastro de pasos vibrantes"},{"start":47.0,"end":50.0,"text":"Mira c\u00f3mo juegan los peque\u00f1os en el dosel"},{"start":52.0,"end":55.0,"text":"Dos cr\u00edas de chimpanc\u00e9 saltan sobre la piel"},{"start":55.0,"end":58.0,"text":"De la madre que vigila, fuerza y calma"},{"start":59.0,"end":64.0,"text":"El Bioparc guarda el latido de un alma salvaje y pura"},{"start":66.0,"end":71.0,"text":"Teresa r\u00ede con el mono, Miguel se\u00f1ala el sol en el trono de su entorno"},{"start":73.0,"end":76.0,"text":"En la sabana los leones son de arena y de oro"},{"start":76.0,"end":79.0,"text":"Rinocerontes grises el secreto que yo adoro"},{"start":80.0,"end":83.0,"text":"Avestruces r\u00e1pidas, cuellos de jirafa"},{"start":83.0,"end":86.0,"text":"Toda la manada en la luz, la del Turia"},{"start":86.0,"end":89.0,"text":"Sin alambradas, sin la sombra de la furia"},{"start":90.0,"end":93.0,"text":"Sin alambradas, sin la sombra de la furia"},{"start":93.0,"end":97.0,"text":"Miguel se agacha para ver al grupo de exploradores"},{"start":99.0,"end":103.0,"text":"Peque\u00f1os meerkats de alerta, centinelas y se\u00f1ores"},{"start":106.0,"end":111.0,"text":"Ojos curiosos, manos finas en la tierra, In\u00e9s pregunta si en su mundo no hay guerra"},{"start":112.0,"end":118.0,"text":"Nos miran de hito en hito como extra\u00f1os, buscando en nuestros ojos los mismos pelda\u00f1os"},{"start":119.0,"end":122.0,"text":"En la sabana los leones son de arena y de oro"},{"start":122.0,"end":125.0,"text":"Rinocerontes grises el secreto que yo adoro"},{"start":126.0,"end":129.0,"text":"Avestruces r\u00e1pidas, cuellos de jirafa"},{"start":129.0,"end":132.0,"text":"Toda la manada en la luz, la del Turia"},{"start":132.0,"end":135.0,"text":"Sin alambradas, sin la sombra de la furia"},{"start":135.0,"end":138.0,"text":"Sin alambradas, sin la sombra de la furia"},{"start":140.0,"end":144.0,"text":"Valencia guarda el rugido, lo envuelve en verde, el rastro de David y Teresa nunca se pierde"},{"start":146.0,"end":151.0,"text":"Raquel e In\u00e9s vuelven a casa con la manada, la aventura en el Bioparc no se acaba"},{"start":152.0,"end":155.0,"text":"Ma\u00f1ana vuelve el sol y la sabana espera"},{"start":155.0,"end":157.0,"text":"Y la sabana espera"}],"instrumental_ranges":[{"start":0.0,"end":13.0}],"beats":[0.12,0.56,0.95,1.37,1.79,2.21,2.62,3.04,3.44,3.85,4.27,4.69,5.11,5.53,5.92,6.34,6.76,7.15,7.57,7.99,8.41,8.82,9.2